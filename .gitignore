# Swift Package Manager / Xcode build artifacts
.build/
# Transient out-of-tree build dirs (e.g. .build-ios-rel/, .build-ios-studio/) —
# alternate SwiftPM/Xcode output roots; derived artifacts, never committed.
.build-*/
hid-bridge/build/
DerivedData/
*.o
*.swiftmodule

# Local work / tooling dirs (transient — never committed).
# /.work/ = repo-root scratch: build logs, the iOS DerivedData (-derivedDataPath .work/ios-dd),
#           xcframework backups, etc. (ThirdParty/ghostty/.work/ is ignored separately below.)
# .claude/ = Claude Code session state (scheduled_tasks.lock, etc.).
/.work/
.claude/

# Xcode user state
*.xcuserstate
xcuserdata/
.swiftpm/xcode/

# macOS
.DS_Store

# WF-8 Xcode app projects — generated from the committed project.yml (source of truth).
# Regenerate with: xcodegen generate --spec Apps/<App>/project.yml
# The .xcodeproj is derived; the project.yml + sources + Info.plist + entitlements are
# the committed deliverable.
Apps/**/*.xcodeproj

# NOTE: Package.resolved is intentionally NOT ignored — pin the dependency graph.

# WF-5 libghostty build infra — derived / large artifacts (the SCRIPT is committed;
# the toolchain, cloned source, and built binary are reproducible from pinned SHAs).
# NOTE: .gitignore does NOT support inline comments — patterns must stand alone.
# .toolchain/ = downloaded pinned Zig (~80 MB extracted).
# .work/      = shallow clone of pinned ghostty fork + Zig caches.
# *.xcframework/ = assembled XCFramework (built artifact; fork emits "GhosttyKit").
ThirdParty/ghostty/.toolchain/
ThirdParty/ghostty/.work/
ThirdParty/ghostty/build/
ThirdParty/ghostty/libghostty.xcframework/
ThirdParty/ghostty/GhosttyKit.xcframework/
*.xcframework/
# Defensive: any *.xcframework* sibling (e.g. a "*.xcframework.incomplete-bak" repair
# backup left by an artifact-rebuild step). The "*.xcframework/" pattern above only
# matches the exact ".xcframework/" directory boundary, not ".xcframework.<suffix>".
ThirdParty/ghostty/*.xcframework*
