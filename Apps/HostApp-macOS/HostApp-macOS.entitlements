<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The host LISTENS for inbound mux connections (the client app is network.client).

	     NOT sandboxed (no com.apple.security.app-sandbox): the host forks the user's login
	     shell via PTY fork/exec, and will later need Screen Recording / Accessibility (TCC)
	     for the GUI-video + remote-input features — App Sandbox would block both. This
	     mirrors aislopdesk-hostd, which runs unsandboxed. -->
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
