// CGhostty — Clang module exposing the libghostty C-ABI to Swift.
//
// Renderer policy: libghostty is the ONLY terminal renderer for Aislopdesk
// (no SwiftTerm, no fallback — see docs/DECISIONS.md "Terminal renderer").
//
// This module is INTENTIONALLY OUTSIDE the default `swift build` graph (it is
// not wired into any Package.swift target or product). It is consumed only by
// the macOS/iOS GUI app target (WF-8), which links the built
// `libghostty.xcframework`. A plain `swift build` / `swift test` of the
// headless core never sees this module, so the 187-test core stays green with
// zero conditional-compilation hacks. See ThirdParty/ghostty/README.md.
//
// `ghostty.h` here is the EXACT header vendored from the pinned source
// (daiimus/ghostty @ ios-external-backend, SHA 21c717340b62349d67124446c2447bf38796540b).
// `build-libghostty.sh` re-installs the identical header into the xcframework;
// the GUI app's framework search path resolves the link-time symbols. The
// committed copy lets a reviewer check GhosttySurface.swift against the real
// API without first running the (Zig-dependent) build.
module CGhostty {
    header "ghostty.h"
    export *
    link "ghostty"
}
