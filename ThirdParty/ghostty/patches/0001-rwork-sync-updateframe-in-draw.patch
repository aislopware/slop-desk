diff --git a/src/Surface.zig b/src/Surface.zig
index 8afe6f7..9556899 100644
--- a/src/Surface.zig
+++ b/src/Surface.zig
@@ -989,6 +989,20 @@ fn queueIo(
 pub fn draw(self: *Surface) !void {
     // Renderers are required to support `drawFrame` being called from
     // the main thread, so that they can update contents during resize.
+    //
+    // Rebuild the frame cells synchronously here so this call is a complete
+    // update+draw on the CALLING (app/main) thread, not just a re-present of
+    // stale cells. The normal cell rebuild path (renderer thread:
+    // wakeupCallback -> renderCallback -> updateFrame) only runs when the
+    // renderer thread's libxev `wakeup` async is delivered. On platforms where
+    // that async is not pumped after the initial startup notify (observed on
+    // the iOS Simulator), updateFrame never re-runs and every drawFrame paints
+    // an empty cell buffer (background only, no glyphs). Doing updateFrame here
+    // makes a synchronous `ghostty_surface_draw` reflect current terminal
+    // content regardless of the renderer thread. updateFrame locks
+    // renderer_state.mutex internally, so this is safe to call from the app
+    // thread once the write_output critical section has released the lock.
+    try self.renderer.updateFrame(&self.renderer_state, true);
     try self.renderer.drawFrame(true);
 }
 
