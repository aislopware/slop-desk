+/// Same as `queueWrite` but assumes the caller ALREADY holds
+/// `renderer_state.mutex`. Use this from code paths that run inside the
+/// renderer-state critical section (e.g. `sizeReportLocked`,
+/// `colorSchemeReportLocked`). Calling `queueWrite` from such a context would
+/// try to recursively lock the (non-recursive) `os_unfair_lock` and abort the
+/// whole process ("BUG IN CLIENT OF LIBPLATFORM: Trying to recursively lock an
+/// os_unfair_lock"). In practice this fires when a full-screen TUI
+/// (vim/htop/tmux/less) sends a size or color-scheme DSR query while a
+/// resize/report is in flight — i.e. the terminal crashes the moment you open
+/// any such app. The tmux-viewer wrapping below is identical to `queueWrite`'s,
+/// minus the mutex acquisition (the caller owns it).
+fn queueWriteLocked(
+    self: *Termio,
+    td: *ThreadData,
+    data: []const u8,
+    linefeed: bool,
+) !void {
+    if (comptime StreamHandler.tmux_enabled) {
+        const viewer = self.terminal_stream.handler.tmux_viewer;
+        if (viewer) |v| {
+            for (v.next(.{ .send_keys = data })) |action| {
+                switch (action) {
+                    .command => |cmd| {
+                        try self.backend.queueWrite(self.alloc, td, cmd, false);
+                    },
+                    else => {},
+                }
+            }
+            // Handle linefeed as a separate send-keys for CR.
+            if (linefeed) {
+                for (v.next(.{ .send_keys = &[_]u8{'\r'} })) |action| {
+                    switch (action) {
+                        .command => |cmd| {
+                            try self.backend.queueWrite(self.alloc, td, cmd, false);
+                        },
+                        else => {},
+                    }
+                }
+            }
+            return;
+        }
+    }
+    try self.backend.queueWrite(self.alloc, td, data, linefeed);
+}
